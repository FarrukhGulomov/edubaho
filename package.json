{
  "name": "edureyting",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:migrate": "turbo db:migrate --filter=@edureyting/api",
    "db:generate": "turbo db:generate --filter=@edureyting/api",
    "db:seed": "turbo db:seed --filter=@edureyting/api",
    "db:studio": "cd apps/api && npx prisma studio"
  },
  "devDependencies": {
    "turbo": "^2.1.3"
  },
  "packageManager": "npm@10.9.2",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
