# ─── Database ───────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Redis ──────────────────────────────────────
REDIS_URL=redis://:password@host:6379

# ─── JWT ────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
REFRESH_SECRET=your-super-secret-refresh-key-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=30d

# ─── SMS (Playmobile) ────────────────────────────
SMS_LOGIN=your-playmobile-login
SMS_PASSWORD=your-playmobile-password
SMS_FROM=EduReyting
SMS_BASE_URL=http://91.204.239.44/broker-api/send

# ─── Meilisearch ────────────────────────────────
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_KEY=your-meilisearch-master-key

# ─── Cloudflare R2 ──────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=edureyting-media
R2_PUBLIC_URL=https://media.edureyting.uz

# ─── App ────────────────────────────────────────
PORT=3001
NODE_ENV=production
ALLOWED_ORIGINS=https://your-web-app.railway.app

# ─── Admin ──────────────────────────────────────
ADMIN_PIN=your-secret-admin-pin
