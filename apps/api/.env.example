# ═══════════════════════════════════════════════════════════════
# EDUBAHO API — Production muhit o'zgaruvchilari
# Railway'da: Service → Variables bo'limiga qo'shing
# ═══════════════════════════════════════════════════════════════

# ─── Database (MAJBURIY) ─────────────────────────
# Railway Postgres: DATABASE_URL avtomatik beriladi (Reference Variable)
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Migratsiyalar uchun to'g'ridan-to'g'ri ulanish.
# Pooler ishlatmasangiz DATABASE_URL bilan bir xil qiymat qo'ying.
DIRECT_URL=postgresql://user:password@host:5432/dbname

# ─── Redis (MAJBURIY) ────────────────────────────
# Railway Redis: REDIS_URL avtomatik beriladi
REDIS_URL=redis://:password@host:6379

# ─── JWT (MAJBURIY, har biri kamida 32 belgi, BIR XIL BO'LMASIN) ─
# Yaratish: openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32-natijasini-qoying
REFRESH_SECRET=change-me-boshqa-openssl-rand-hex-32-qiymat
JWT_EXPIRES_IN=15m
REFRESH_EXPIRES_IN=30d

# ─── App (MAJBURIY) ──────────────────────────────
PORT=3001
NODE_ENV=production
# Vergul bilan ajratilgan frontend domenlari (Vercel domeningiz)
ALLOWED_ORIGINS=https://edubaho.vercel.app,https://edubaho.uz

# ─── Admin (MAJBURIY) ────────────────────────────
# Production'da kamida 6 belgi, '1234'/'147258' TAQIQLANGAN — server ishga tushmaydi
ADMIN_PIN=kuchli-maxfiy-pin

# ─── SMS Playmobile (ixtiyoriy — bo'lmasa OTP faqat logga chiqadi) ─
SMS_LOGIN=
SMS_PASSWORD=
SMS_FROM=EDULA
SMS_BASE_URL=http://91.204.239.44/broker-api/send

# ─── Telegram Login (ixtiyoriy — bo'lmasa Telegram kirish o'chiq) ─
# @BotFather'dan bot token
TELEGRAM_BOT_TOKEN=

# ─── Google OAuth (ixtiyoriy — bo'lmasa Gmail kirish o'chiq) ─────
# console.cloud.google.com → Credentials → OAuth Client ID (Web)
GOOGLE_CLIENT_ID=

# ─── Meilisearch (ixtiyoriy — bo'lmasa qidiruv DB orqali ishlaydi) ─
MEILISEARCH_URL=
MEILISEARCH_KEY=

# ─── Cloudflare R2 (ixtiyoriy — bo'lmasa fayl yuklash o'chiq) ────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=edubaho-media
R2_PUBLIC_URL=https://media.edubaho.uz

# ─── XAVFSIZLIK OGOHLANTIRISHI ──────────────────
# ALLOW_DEV_OTP ni production'da HECH QACHON yoqmang — server o'zi rad etadi
# ALLOW_DEV_OTP=false
