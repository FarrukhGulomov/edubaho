# ═══════════════════════════════════════════════════════════════
# EDUBAHO Web — Production muhit o'zgaruvchilari
# Vercel'da: Project → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════

# API manzili (Railway'dagi API servis domeni + /api/v1)
NEXT_PUBLIC_API_URL=https://your-api.up.railway.app/api/v1

# Sayt manzili (SEO/canonical uchun)
NEXT_PUBLIC_SITE_URL=https://edubaho.uz

NEXT_PUBLIC_APP_NAME="EDULA"

# Telegram Login Widget bot username (API'dagi TELEGRAM_BOT_TOKEN bilan bir bot)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=edubahobot

# Google OAuth Client ID (API'dagi GOOGLE_CLIENT_ID bilan BIR XIL qiymat)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Google Maps (ixtiyoriy, xarita uchun)
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
